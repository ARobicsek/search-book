# Local development (SQLite)
DATABASE_URL="file:./dev.db"

# Production (Turso) - set in Vercel dashboard
# TURSO_DATABASE_URL="libsql://your-database-name.turso.io"
# TURSO_AUTH_TOKEN="your-auth-token"

# Production (Vercel Blob for photos) - auto-set when you enable Blob in Vercel dashboard
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# OpenAI API key for LinkedIn profile parsing (Import from LinkedIn feature)
# OPENAI_API_KEY="sk-proj-..."

# ── Web Push action reminders (all optional; reminders are off until these are set) ──
# Generate the VAPID key pair once: `npx web-push generate-vapid-keys`
# VAPID_PUBLIC_KEY="B..."           # the client fetches this at runtime from /api/push/public-key
# VAPID_PRIVATE_KEY="..."
# VAPID_SUBJECT="mailto:ari.robicsek@gmail.com"
# Shared secret the external cron uses to call /api/cron/reminders (reuse the backup CRON_SECRET).
# CRON_SECRET="..."
# Owner timezone for converting an action's wall-clock dueDate+dueTime into a real instant.
# REMINDER_TZ="America/New_York"
