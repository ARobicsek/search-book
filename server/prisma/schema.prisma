generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Contacts ────────────────────────────────────────────────

model Contact {
  id                Int      @id @default(autoincrement())
  name              String
  // How to address / pronounce this person ("Ben"; "Viv-ACHE"). Kept OUT of `name`
  // so the formal name stays clean for CSV joins/imports/exports; the UI recombines
  // them at display time as "name (preferredName)". See contactDisplayName() client-side.
  preferredName     String?
  title             String?
  roleDescription   String?
  companyId         Int?
  company           Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyName       String?
  additionalCompanyIds String?  // JSON array: [2, 5, 7] - IDs of additional current companies
  connectedCompanyIds  String?  // JSON array: [2, 5, 7] - IDs of connected companies
  ecosystem         String   @default("RECRUITER") // PAYER, PROVIDER, GOVERNMENT, ACADEMIA, HEALTH_TECH, POLICY, MEDIA, FUNDER, NCQA, NETWORK, RECRUITER (DDL default kept as RECRUITER to avoid a table rebuild; client always sends explicitly, defaulting to NETWORK)
  email             String?
  additionalEmails  String?  // JSON array: ["email2@x.com", "email3@x.com"]
  phone             String?
  linkedinUrl       String?
  location          String?
  photoUrl          String?
  photoFile         String?
  status            String   @default("NEW") // NONE (blank), RESEARCHING, CONNECTED, AWAITING_RESPONSE, FOLLOW_UP_NEEDED (DDL default kept as NEW to avoid a table rebuild; client always sends explicitly)
  howConnected      String?
  referredById      Int?
  referredBy        Contact?  @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals         Contact[] @relation("Referrals")
  mutualConnections String?
  whereFound        String?
  openQuestions     String?
  notes             String?
  personalDetails   String?
  usefulFor         String?  // Free text: what this person could help NCQA with in future (topic/collaboration). Non-empty = a "useful person"; drives the contacts "Useful people" filter + search.
  flagged           Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  statusHistory            ContactStatusHistory[]
  tags                     ContactTag[]
  conversations            Conversation[]
  actions                  Action[]
  linksTo                  Link[]
  prepNotes                PrepNote[]
  employmentHistory        EmploymentHistory[]
  relationshipsFrom        Relationship[] @relation("RelFrom")
  relationshipsTo          Relationship[] @relation("RelTo")
  participantInConversations ConversationParticipant[] @relation("ParticipantInConversations")
  discussedInConversations ConversationContact[] @relation("DiscussedInConversations")
  mentionedInConversations ConversationMention[] @relation("MentionedInConversations")
  ideaContacts             IdeaContact[]
  actionContacts           ActionContact[] @relation("ActionContacts")
}

// ─── Companies ───────────────────────────────────────────────

model Company {
  id         Int      @id @default(autoincrement())
  name       String
  industry   String?
  size       String?
  website    String?
  hqLocation String?
  notes      String?
  status     String   @default("RESEARCHING") // NONE (blank), RESEARCHING, ENGAGED, PARTNER, CONNECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  statusHistory            CompanyStatusHistory[]
  contacts                 Contact[]
  tags                     CompanyTag[]
  actions                  Action[]
  links                    Link[]
  anchoredConversations    Conversation[]
  discussedInConversations ConversationCompany[]
  orgConversations         ConversationOrg[]     @relation("OrgConversations")
  employmentHistory        EmploymentHistory[]
  ideaCompanies            IdeaCompany[]
  actionCompanies          ActionCompany[] @relation("ActionCompanies")
  activities               CompanyActivity[]
  companyPrepNotes         CompanyPrepNote[]
  mentionedInConversations ConversationMention[] @relation("OrgMentionedInConversations")
}

// ─── Company Activities (company-level action log) ──────────

model CompanyActivity {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD
  type      String   @default("OTHER") // APPLIED, EMAIL, CALL, MEETING, RESEARCH, FOLLOW_UP, OTHER
  title     String   // Brief summary, e.g. "Applied to Senior PM role"
  notes     String?  // Optional detailed notes (supports markdown)
  createdAt DateTime @default(now())
}

// ─── Status History ─────────────────────────────────────────

model ContactStatusHistory {
  id          Int      @id @default(autoincrement())
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  oldStatus   String?
  newStatus   String
  createdAt   DateTime @default(now())
}

model CompanyStatusHistory {
  id          Int      @id @default(autoincrement())
  companyId   Int
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  oldStatus   String?
  newStatus   String
  createdAt   DateTime @default(now())
}

// ─── Employment History ─────────────────────────────────────

model EmploymentHistory {
  id          Int      @id @default(autoincrement())
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  companyId   Int?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyName String?  // Fallback if company doesn't exist in system
  title       String?  // Role at that company
  startDate   String?  // YYYY-MM or YYYY
  endDate     String?  // YYYY-MM or YYYY, null = current
  createdAt   DateTime @default(now())
}

// ─── Tags ────────────────────────────────────────────────────

model Tag {
  id            Int               @id @default(autoincrement())
  name          String            @unique
  contacts      ContactTag[]
  companies     CompanyTag[]
  conversations ConversationTag[]
  ideas         IdeaTag[]
}

model ContactTag {
  contactId Int
  tagId     Int
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model CompanyTag {
  companyId Int
  tagId     Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([companyId, tagId])
}

// ─── Conversations ───────────────────────────────────────────

// A Conversation is a meeting record with four independent "who" facets, all
// optional, at least one required (enforced in routes/conversations.ts):
// anchor contact (the legacy 1:1 case), org anchor, named participants, or a
// free-text attendees description. `title` is the series key for recurring
// meetings ("Weekly VP meeting") — autocompleted so spellings stay consistent.
model Conversation {
  id                   Int      @id @default(autoincrement())
  contactId            Int?
  contact              Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title                String?
  companyId            Int?
  company              Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  attendeesDescription String?
  date                 String
  datePrecision        String   @default("DAY") // DAY, MONTH, QUARTER, YEAR
  type                 String   @default("OTHER") // CALL, EMAIL, MEETING, LINKEDIN, COFFEE, EVENT, OTHER
  summary              String?
  notes                String?
  nextSteps            String?
  photoFile            String?
  startTime            String?  // Local HH:MM start time (meetings are otherwise date-only); set by Outlook import, editable in Quick Log
  calendarUid          String?  // Outlook ICS UID for idempotent re-import. Dedup key = calendarUid + date (recurring occurrences share one UID)
  seriesId             Int?
  series               Series?  @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  actions            Action[]
  participants       ConversationParticipant[] @relation("ConversationParticipants")
  contactsDiscussed  ConversationContact[]
  companiesDiscussed ConversationCompany[]
  orgs               ConversationOrg[]         @relation("ConversationOrgs")
  tags               ConversationTag[]
  prepNotes          ConversationPrepNote[]
  attachments        ConversationAttachment[]
  mentions           ConversationMention[]

  @@index([calendarUid])
}

// People @-mentioned inside a meeting's notes — captured inline while typing
// ("someone you met mentioned a third person"), reviewed later. `contactId` is
// null for a "loose" mention (a name that isn't a contact yet); `mentionedName`
// is always the typed display name. These rows are DERIVED from the note text on
// every conversation save (parse the @[Name](…) tokens → delete-all + re-create
// for that meeting), so the note text stays the source of truth.
model ConversationMention {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  // A mention targets either a person (contactId) or an organization (companyId).
  // `kind` ('CONTACT' | 'COMPANY') disambiguates loose mentions, where both ids
  // are null (a name/org not in the CRM yet). `mentionedName` is the typed text.
  kind           String       @default("CONTACT")
  contactId      Int?
  contact        Contact?     @relation("MentionedInConversations", fields: [contactId], references: [id], onDelete: SetNull)
  companyId      Int?
  company        Company?     @relation("OrgMentionedInConversations", fields: [companyId], references: [id], onDelete: SetNull)
  mentionedName  String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([contactId])
  @@index([companyId])
}

// A recurring meeting series (D4 revised): meetings opt into a series explicitly
// and later meetings join it from a picker, instead of relying on byte-identical
// titles. Replaces the old "series == title string" convention.
model Series {
  id            Int            @id @default(autoincrement())
  name          String
  createdAt     DateTime       @default(now())
  conversations Conversation[]
}

// Prep notes attached to a specific meeting (incl. one logged in advance with a
// future date) — the meeting-level analog of PrepNote/CompanyPrepNote.
model ConversationPrepNote {
  id             Int          @id @default(autoincrement())
  content        String       // Free text for thoughts, ideas (markdown)
  url            String?      // Optional URL for document/web links
  urlTitle       String?      // Optional title for the URL
  date           String       // Target date for this prep (YYYY-MM-DD)
  ordering       Int          @default(0)
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

// Files attached to a meeting (screenshots, decks, PDFs). `url` is a Vercel
// Blob URL in production or a local `/files/...` path in dev — binaries follow
// the photo precedent: not part of the daily DB backup.
model ConversationAttachment {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  url            String
  name           String       // Original filename, for display
  mimeType       String?
  size           Int?         // Bytes
  createdAt      DateTime     @default(now())
}

// Junction: contacts who were participants in the conversation.
// `note` is the per-person takeaway ("skeptical of digital-first HEDIS") —
// surfaced on the contact's detail page as a meeting-takeaways timeline.
model ConversationParticipant {
  conversationId Int
  conversation   Conversation @relation("ConversationParticipants", fields: [conversationId], references: [id], onDelete: Cascade)
  contactId      Int
  contact        Contact      @relation("ParticipantInConversations", fields: [contactId], references: [id], onDelete: Cascade)
  note           String?
  // Entry order within the meeting (0-based). Drives the displayed meeting title
  // when no title is set (first participant entered). Set on create from the
  // submitted array index; without it, reads come back in arbitrary index order.
  ordering       Int     @default(0)

  @@id([conversationId, contactId])
}

// Junction: tags on a conversation (reuses the existing Tag entity)
model ConversationTag {
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tagId          Int
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
}

// Junction: people discussed in a conversation
model ConversationContact {
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contactId      Int
  contact        Contact      @relation("DiscussedInConversations", fields: [contactId], references: [id], onDelete: Cascade)

  @@id([conversationId, contactId])
}

// Junction: organizations the meeting was WITH, beyond the single anchor
// companyId (which stays the "primary" org for backward compat — mirrors
// Contact.additionalCompanyIds). Distinct from ConversationCompany, which
// records orgs *discussed* in the meeting.
model ConversationOrg {
  conversationId Int
  conversation   Conversation @relation("ConversationOrgs", fields: [conversationId], references: [id], onDelete: Cascade)
  companyId      Int
  company        Company      @relation("OrgConversations", fields: [companyId], references: [id], onDelete: Cascade)

  @@id([conversationId, companyId])
}

// Junction: companies discussed in a conversation
model ConversationCompany {
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  companyId      Int
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([conversationId, companyId])
}

// ─── Actions ─────────────────────────────────────────────────

model Action {
  id                    Int           @id @default(autoincrement())
  title                 String
  description           String?
  type                  String        @default("OTHER") // EMAIL, CALL, READ, WRITE, RESEARCH, FOLLOW_UP, INTRO, OTHER
  dueDate               String?
  // Optional time of day for the due date, "HH:MM" 24h local (REMINDER_TZ). Null = no time (the default).
  // Kept SEPARATE from dueDate (which stays date-only "YYYY-MM-DD" for the app-wide string comparisons/sorting).
  dueTime               String?
  // Opt-in reminder. Independent of dueTime: a time can be set with no alert, or an alert with no
  // explicit time (cron defaults to 08:00 weekdays / 10:00 weekends in REMINDER_TZ). Default false ⇒ existing actions never alert.
  notify                Boolean       @default(false)
  // ISO timestamp the cron writes when it sends the Web Push, so a reminder fires exactly once.
  lastNotifiedAt        String?
  completed             Boolean       @default(false)
  completedDate         String?
  contactId             Int?
  contact               Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId             Int?
  company               Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  conversationId        Int?
  conversation          Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  priority              String        @default("MEDIUM") // HIGH, MEDIUM, LOW
  direction             String        @default("OWED_BY_ME") // OWED_BY_ME, WAITING_ON_THEM — DERIVED mirror of owedByMe/owerContactIds (kept so dashboard "Waiting on others" + ?filter=waiting + analytics read it unchanged)
  owedByMe              Boolean       @default(true) // Task 3: am I on the hook? (the removable "me" chip)
  owerContactIds        String?       // Task 3: JSON array of contact ids who owe it (null/empty = nobody specific)
  recurring             Boolean       @default(false)
  recurringIntervalDays Int?
  // When true, the recurrence advances to the next weekday (Mon–Fri), skipping
  // Sat/Sun — recurringIntervalDays is ignored (there is no fixed day interval).
  recurringWeekdaysOnly Boolean       @default(false)
  recurringEndDate      String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  links                 Link[]
  actionContacts        ActionContact[]
  actionCompanies       ActionCompany[]
}

// Junction: contacts associated with an action
model ActionContact {
  actionId  Int
  action    Action  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  contactId Int
  contact   Contact @relation("ActionContacts", fields: [contactId], references: [id], onDelete: Cascade)

  @@id([actionId, contactId])
}

// Junction: companies associated with an action
model ActionCompany {
  actionId  Int
  action    Action  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  companyId Int
  company   Company @relation("ActionCompanies", fields: [companyId], references: [id], onDelete: Cascade)

  @@id([actionId, companyId])
}

// ─── Web Push subscriptions ──────────────────────────────────
// Single-user app: every row is one browser/device the owner enabled action reminders on.
// The cron endpoint (/api/cron/reminders) fans out a Web Push to every subscription here.
model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String   // client public key (from PushSubscription.getKey('p256dh'))
  auth      String   // client auth secret (from PushSubscription.getKey('auth'))
  createdAt DateTime @default(now())
}

// ─── Ideas ───────────────────────────────────────────────────

model Idea {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  tags        String?  // Legacy comma-separated tags — superseded by the IdeaTag junction (kept for back-compat; backfilled into IdeaTag)
  archived    Boolean  @default(false) // Soft-archive: hidden from the default Ideas list/search; revealed via the lozenge filter
  createdAt   DateTime @default(now())

  contacts    IdeaContact[]
  companies   IdeaCompany[]
  tagLinks    IdeaTag[]
}

// Junction: tags on an idea (shares the app-wide Tag entity with contacts/companies/meetings)
model IdeaTag {
  ideaId Int
  idea   Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  tagId  Int
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ideaId, tagId])
}

// Junction: contacts associated with an idea
model IdeaContact {
  ideaId    Int
  idea      Idea    @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  contactId Int
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([ideaId, contactId])
}

// Junction: companies associated with an idea
model IdeaCompany {
  ideaId    Int
  idea      Idea    @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([ideaId, companyId])
}

// ─── Links ───────────────────────────────────────────────────

model Link {
  id          Int      @id @default(autoincrement())
  url         String
  title       String
  description String?
  contactId   Int?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId   Int?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  actionId    Int?
  action      Action?  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

// ─── Prep Notes ─────────────────────────────────────────────

model PrepNote {
  id        Int      @id @default(autoincrement())
  content   String   // Free text for thoughts, ideas
  url       String?  // Optional URL for document/web links
  urlTitle  String?  // Optional title for the URL
  date      String   // Target date for this prep (YYYY-MM-DD)
  ordering  Int      @default(0)
  contactId Int
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ─── Company Prep Notes (Research Dossier) ──────────────────

model CompanyPrepNote {
  id        Int      @id @default(autoincrement())
  content   String   // Free text for thoughts, ideas
  url       String?  // Optional URL for document/web links
  urlTitle  String?  // Optional title for the URL
  date      String   // Target date for this prep (YYYY-MM-DD)
  ordering  Int      @default(0)
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ─── Relationships ───────────────────────────────────────────

model Relationship {
  id            Int     @id @default(autoincrement())
  fromContactId Int
  fromContact   Contact @relation("RelFrom", fields: [fromContactId], references: [id], onDelete: Cascade)
  toContactId   Int
  toContact     Contact @relation("RelTo", fields: [toContactId], references: [id], onDelete: Cascade)
  type          String  // REFERRED_BY, WORKS_WITH, KNOWS, INTRODUCED_BY, REPORTS_TO
  notes         String?
}

// ─── Undo (snapshot-and-replay) ──────────────────────────────
// One row per delete. `payload` is the JSON capture of everything the delete
// destroyed/mutated (cascade rows to re-insert, SetNull'd FKs to restore, JSON-array
// scrubs to re-add). Rows form a small stack — `POST /api/undo` pops the most recent
// and replays it. Pruned to the last ~25 on each delete. See server/src/lib/undo.ts.
// Dismissed duplicate pairs — keyed by normalized name so dismissals survive re-imports
// with new IDs. type: "contact" | "company". nameKey1 <= nameKey2 alphabetically.
model DismissedDuplicate {
  id        Int      @id @default(autoincrement())
  type      String   // "contact" | "company"
  nameKey1  String
  nameKey2  String
  createdAt DateTime @default(now())

  @@unique([type, nameKey1, nameKey2])
}

// Merge rules — when A was merged into B, future reimports of A auto-merge into B.
// type: "contact" | "company". removedKey: normalized name of the deleted entity.
// keptKey: normalized name of the surviving entity.
model DuplicateMergeRule {
  id          Int      @id @default(autoincrement())
  type        String   // "contact" | "company"
  removedKey  String   // normalized name that was deleted
  keptKey     String   // normalized name that survived
  createdAt   DateTime @default(now())

  @@unique([type, removedKey])
}

model DeletedSnapshot {
  id         Int      @id @default(autoincrement())
  entityType String   // delegate name: 'contact' | 'company' | 'conversation' | 'action' | ...
  entityId   Int      // original primary id (for the label / de-dupe)
  label      String   // human description, e.g. "Meeting: Weekly VP sync"
  payload    String   // JSON: { inserts, fkRestores, jsonRestores }
  createdAt  DateTime @default(now())
}
