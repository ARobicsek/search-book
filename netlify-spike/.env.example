# Env vars to set in the Netlify dashboard (Site settings → Environment variables) for the SPIKE.
# Copy values from the Vercel dashboard. For local `netlify dev`, copy this to `.env`.

# Turso — SAFE to point at prod (dbcount is read-only, COUNT(*) only). Or use a scratch DB.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# OpenAI — for the server-side timing test (0.3 / R2). Same key the app uses.
OPENAI_API_KEY=

# Cron secret — for the reminders trigger test (0.6 / R11). Match cron-job.org's ?key=.
REMINDERS_CRON_SECRET=
# CRON_SECRET=   # fallback the reminders function also accepts
